---
export const prerender = true;
const redirect = Astro.url.searchParams.get('redirect') || '/';
const apiUrl = import.meta.env.PUBLIC_API_URL || '';
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>验证邮箱 - Hosted PPT</title>
  <style>
    :root {
      color-scheme: dark;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --bg-a: #0f172a;
      --bg-b: #111827;
      --card: rgba(15,23,42,.78);
      --line: rgba(255,255,255,.16);
      --text: #f8fafc;
      --muted: #cbd5e1;
      --accent: #f0abfc;
      --accent-2: #93c5fd;
      --danger: #fca5a5;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0; min-height: 100vh; display: grid; place-items: center;
      background: radial-gradient(circle at top left, rgba(245,208,254,.9), transparent 30rem),
        radial-gradient(circle at bottom right, rgba(59,130,246,.45), transparent 34rem),
        linear-gradient(135deg, var(--bg-a), var(--bg-b));
      color: var(--text);
    }
    main { width: min(420px, calc(100vw - 40px)); padding: 36px 28px; border: 1px solid var(--line);
      border-radius: 24px; background: var(--card); backdrop-filter: blur(14px);
      box-shadow: 0 24px 80px rgba(0,0,0,.35); }
    h1 { margin: 0 0 8px; font-size: clamp(1.6rem, 6vw, 2.4rem); letter-spacing: -0.04em; }
    p { color: var(--muted); margin: 0 0 20px; }
    label { display: block; margin-bottom: 4px; color: var(--muted); font-size: .85rem; font-weight: 600; }
    .field { margin-bottom: 14px; }
    input { width: 100%; min-height: 48px; padding: 0 14px; border-radius: 12px;
      border: 1px solid var(--line); background: rgba(255,255,255,.06); color: var(--text); font: inherit; outline: none; }
    input:focus { border-color: rgba(147,197,253,.7); box-shadow: 0 0 0 4px rgba(147,197,253,.14); }
    button { width: 100%; min-height: 48px; border: none; border-radius: 12px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: #0f172a;
      font: inherit; font-weight: 800; cursor: pointer; }
    button:disabled { opacity: .6; cursor: wait; }
    .error { min-height: 24px; margin-top: 10px; color: var(--danger); font-size: .9rem; }
  </style>
</head>
<body>
  <main>
    <h1>验证邮箱</h1>
    <p>请输入邮箱获取验证码，即可访问展示页。</p>
    <form id="email-form" autocomplete="off">
      <div class="field">
        <label for="email">邮箱</label>
        <input id="email" type="email" inputmode="email" placeholder="your@email.com" required />
      </div>
      <button type="submit" id="email-submit">获取验证码</button>
    </form>
    <form id="code-form" autocomplete="off" style="display:none;">
      <div class="field">
        <label for="code">验证码</label>
        <input id="code" type="text" inputmode="numeric" placeholder="6位验证码" maxlength="6" required />
      </div>
      <button type="submit" id="code-submit">验证并继续</button>
    </form>
    <div id="error" class="error" role="alert"></div>
  </main>
  <script is:inline define:vars={{ apiUrl, redirect }}>
    const REDIRECT = decodeURIComponent(redirect);
    const emailForm = document.getElementById('email-form');
    const codeForm = document.getElementById('code-form');
    const error = document.getElementById('error');

    emailForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      error.textContent = '';
      const btn = document.getElementById('email-submit');
      btn.disabled = true;
      try {
        const res = await fetch(apiUrl + '/api/auth/email/request', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: document.getElementById('email').value }),
        });
        const body = await res.json();
        if (!res.ok) { error.textContent = body?.error?.message || '请求失败'; btn.disabled = false; return; }
        emailForm.style.display = 'none';
        codeForm.style.display = 'block';
      } catch { error.textContent = '网络错误'; btn.disabled = false; }
    });

    codeForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      error.textContent = '';
      const btn = document.getElementById('code-submit');
      btn.disabled = true;
      try {
        const res = await fetch(apiUrl + '/api/auth/email/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ email: document.getElementById('email').value, code: document.getElementById('code').value }),
        });
        const body = await res.json();
        if (!res.ok) { error.textContent = body?.error?.message || '验证失败'; btn.disabled = false; return; }
        window.location.href = REDIRECT;
      } catch { error.textContent = '网络错误'; btn.disabled = false; }
    });
  </script>
</body>
</html>
