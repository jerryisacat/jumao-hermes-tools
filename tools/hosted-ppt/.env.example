# ============================================
# Environment Variables Template
# Copy to .env for local development.
# NEVER commit actual values.
# ============================================

# --- Railway ---
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/hosted_ppt
API_KEY_AGENTS=<agent-api-key>
ADMIN_EMAIL=admin@example.com
SESSION_SECRET=<random-session-secret>
RAILWAY_API_URL=https://your-railway-app.up.railway.app

# --- Vercel KV ---
KV_URL=rediss://default:<password>@<host>:6379
KV_REST_API_URL=https://your-kv-url.kv.vercel-storage.com
KV_REST_API_TOKEN=<kv-rest-api-token>

# --- Vercel ---
PUBLIC_BASE_URL=https://your-domain.vercel.app
PUBLIC_API_URL=https://your-railway-app.up.railway.app

# --- Notifications (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_FROM_EMAIL=

# --- Webhook (optional) ---
WEBHOOK_SECRET=
